# MetaTrader 5 (MT5) Trading Account Credentials
MT5_LOGIN=YOUR_MT5_ACCOUNT_NUMBER        # e.g., 316933522 (integer account ID)
MT5_PASSWORD=YOUR_MT5_ACCOUNT_PASSWORD    # e.g., YourSecurePassword!
MT5_SERVER=YOUR_MT5_BROKER_SERVER        # e.g., XMGlobal-MT5 7 (broker server name)

# External API Integrations (Optional / Standardized)
TWELVEDATA_API_KEY=YOUR_TWELVEDATA_KEY   # Used if fetching external benchmark data
LINE_NOTIFY_TOKEN=YOUR_LINE_NOTIFY_TOKEN # Token used for real-time mobile notifications/alerts
